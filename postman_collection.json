{
  "info": {
    "name": "Event Booking System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organizer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Super Organizer\",\"email\":\"org@test.com\",\"password\":\"password123\"}"
            },
            "url": {"raw": "http://localhost:5000/api/auth/organizer/register", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "organizer", "register"]}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"org_token\", jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
