    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event (Organizer)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{org_token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"My New Event\",\"description\":\"Great description of this event.\",\"date\":\"2026-12-12\",\"location\":\"New York, NY\",\"totalTickets\":100,\"availableTickets\":100}"
            },
            "url": {"raw": "http://localhost:5000/api/events", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "events"]}
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/events?page=1&limit=5", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "events"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "5"}]}
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Book Ticket (Customer)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{cust_token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\",\"ticketsCount\":2}"
            },
            "url": {"raw": "http://localhost:5000/api/bookings", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "bookings"]}
          }
        },
        {
          "name": "Get My Bookings (Customer)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{cust_token}}"}],
            "url": {"raw": "http://localhost:5000/api/bookings", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "bookings"]}
          }
        }
      ]
    }
